{
  "manifest_version": 3,
  "name": "Header changer Lite2",
  "version": "1.1",
  "description": "Modifies HTTP request headers for the active tab only.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "activeTab"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}

